import pygame, sys, time

pygame.init()

# Auto-fit ke screen device
screen = pygame.display.set_mode((0, 0), pygame.FULLSCREEN)
width, height = screen.get_size()
pygame.display.set_caption("Brain Adventure")

# Settings icon
settings_icon = pygame.image.load("settings_logo.png")
settings_icon = pygame.transform.smoothscale(settings_icon, (width // 18, height // 18))
settings_rect = settings_icon.get_rect(topright=(width - 25, 25))

# Logo game - besar & lebih atas
logo = pygame.image.load("GAME LOGO.png")
logo = pygame.transform.smoothscale(logo, (width // 2, height // 2))  # besar
logo_rect = logo.get_rect(center=(width // 2, height // 4))  # letak lebih atas

# Buttons (guna image sahaja)
button_width = width // 4   # besar tapi muat
button_height = height // 8
spacing = height // 18
start_y = int(height * 0.5)  # naikkan ke tengah screen

play_img = pygame.image.load("PLAY.png")
play_img = pygame.transform.smoothscale(play_img, (button_width, button_height))

report_img = pygame.image.load("DAILY REPORT.png")
report_img = pygame.transform.smoothscale(report_img, (button_width, button_height))

exit_img = pygame.image.load("EXIT.png")
exit_img = pygame.transform.smoothscale(exit_img, (button_width, button_height))

buttons = {
    "Play": {"rect": pygame.Rect(width // 2 - button_width // 2, start_y, button_width, button_height), "img": play_img},
    "Daily Report": {"rect": pygame.Rect(width // 2 - button_width // 2, start_y + spacing + button_height, button_width, button_height), "img": report_img},
    "Exit": {"rect": pygame.Rect(width // 2 - button_width // 2, start_y + 2 * (spacing + button_height), button_width, button_height), "img": exit_img}
}

# Popup buttons
popup_buttons = {
    "Yes": pygame.Rect(width // 2 - 120, height // 2 + 40, 100, 50),
    "No": pygame.Rect(width // 2 + 20, height // 2 + 40, 100, 50)
}

show_popup = False

# Background scenes (smoothscale untuk HD)
bg_images = [
    pygame.transform.smoothscale(pygame.image.load("intro hp1.png"), (width, height)),
    pygame.transform.smoothscale(pygame.image.load("intro hp2.png"), (width, height)),
    pygame.transform.smoothscale(pygame.image.load("intro hp3.png"), (width, height))
]
bg_index = 0
last_switch = time.time()
switch_interval = 0.5

# Main loop
while True:
    # Background animation
    if time.time() - last_switch > switch_interval:
        bg_index = (bg_index + 1) % len(bg_images)
        last_switch = time.time()
    screen.blit(bg_images[bg_index], (0, 0))

    mouse_pos = pygame.mouse.get_pos()

    if not show_popup:
        # Draw settings icon + hover effect
        if settings_rect.collidepoint(mouse_pos):
            hover_icon = settings_icon.copy()
            hover_icon.fill((50, 50, 50), special_flags=pygame.BLEND_RGB_ADD)
            screen.blit(hover_icon, settings_rect)
        else:
            screen.blit(settings_icon, settings_rect)

        # Draw logo
        screen.blit(logo, logo_rect)

        # Draw buttons (image only + hover effect)
        for name, data in buttons.items():
            rect = data["rect"]
            img = data["img"]

            if rect.collidepoint(mouse_pos):
                hover_img = img.copy()
                hover_img.fill((50, 50, 50), special_flags=pygame.BLEND_RGB_ADD)
                screen.blit(hover_img, rect)
            else:
                screen.blit(img, rect)
    else:
        # Draw popup box
        popup_rect = pygame.Rect(width // 2 - 200, height // 2 - 100, 400, 200)
        pygame.draw.rect(screen, (200, 200, 200), popup_rect, border_radius=10)
        msg_font = pygame.font.SysFont(None, height // 25)
        msg = msg_font.render("Are you sure you want to quit app?", True, (0, 0, 0))
        screen.blit(msg, msg.get_rect(center=(width // 2, height // 2 - 30)))

        # Draw Yes/No buttons
        for text, rect in popup_buttons.items():
            pygame.draw.rect(screen, (245, 245, 220), rect, border_radius=8)
            label = msg_font.render(text, True, (0, 0, 0))
            screen.blit(label, label.get_rect(center=rect.center))

    # Event handling
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit(); sys.exit()
        elif event.type == pygame.MOUSEBUTTONDOWN:
            if not show_popup:
                if buttons["Exit"]["rect"].collidepoint(event.pos):
                    show_popup = True
                elif buttons["Play"]["rect"].collidepoint(event.pos):
                    print("▶️ Start Game")
                elif buttons["Daily Report"]["rect"].collidepoint(event.pos):
                    print("📊 Show Daily Report")
                elif settings_rect.collidepoint(event.pos):
                    print("⚙️ Open Settings")
            else:
                if popup_buttons["Yes"].collidepoint(event.pos):
                    pygame.quit(); sys.exit()
                elif popup_buttons["No"].collidepoint(event.pos):
                    show_popup = False

    pygame.display.flip()